
айыр салам = "Дуниягъа салам!"
чыгар салам

айыр x = 10
айыр y = 5
айыр сумма = x + y
чыгар "x + y = "
чыгар сумма

эгер x > y анда 
    чыгар "x чонду"
болмаса 
    чыгар "y чонду"
бют

айлан i = 0 ден 5 ге чейин
    чыгар i
бют

функция квадрат(сан)
    кайтар сан * сан
бют

айыр беш_квадрат = квадрат(5)
чыгар "5-ни квадраты: "
чыгар беш_квадрат